# ── Aplicação ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET=troque_por_uma_string_longa_e_aleatoria
JWT_EXPIRATION=3600s

# ── Banco de dados ───────────────────────────────────────────
# Formato completo (usado no Railway e em produção):
DATABASE_URL=postgresql://taskman:taskman@db:5432/taskman

# Variáveis separadas (usadas pelo docker-compose):
DB_USER=taskman
DB_PASSWORD=taskman
DB_NAME=taskman
